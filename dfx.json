{
  "canisters": {
    "cardinal": {
      "main": "src/otherland_network/cardinal.mo",
      "type": "motoko"
    },
    "user_node": {
      "main": "src/otherland_network/user_node.mo",
      "type": "motoko"
    },
    "otherland_client": {
      "dependencies": ["cardinal"],
      "source": ["src/otherland_client/dist"],
      "type": "assets",
      "workspace": "otherland_client",
      "headers": {
        "Content-Security-Policy": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; object-src 'none';"
      }
    },
    "internet_identity": {
      "type": "custom",
      "candid": "https://github.com/dfinity/internet-identity/releases/download/release-2026-03-09/internet_identity.did",
      "wasm": "https://github.com/dfinity/internet-identity/releases/download/release-2026-03-09/internet_identity_dev.wasm.gz",
      "frontend": {},
      "remote": {
        "id": {
          "ic": "rdmx6-jaaaa-aaaaa-aaadq-cai"
        }
      }
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": "mops sources"
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral"
    }
  },
  "version": 1
}